# Auth Service — local geliştirme ortamı değişkenleri
# Production'da bu değerler K8s ConfigMap/Secret'tan gelir

# Auth Service DB
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5433
AUTH_DB_USER=auth
AUTH_DB_PASS=auth_pass
AUTH_DB_NAME=auth_db

# Product Service DB
PRODUCT_DB_HOST=localhost
PRODUCT_DB_PORT=5434
PRODUCT_DB_USER=product
PRODUCT_DB_PASS=product_pass
PRODUCT_DB_NAME=product_db

# Order Service DB
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5435
ORDER_DB_USER=order
ORDER_DB_PASS=order_pass
ORDER_DB_NAME=order_db

# Payment Service DB
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5436
PAYMENT_DB_USER=payment
PAYMENT_DB_PASS=payment_pass
PAYMENT_DB_NAME=payment_db

# JWT
JWT_SECRET=omni_super_secret_change_me
JWT_EXPIRES_IN=1d

# Kafka (docker-compose'da kafka servisi)
KAFKA_BROKERS=localhost:9092

# OpenTelemetry → Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Log seviyesi (debug | info | warn | error)
LOG_LEVEL=info
